; Engine configuration file.
;
; nulldrift — Godot 3D iso port of hacking-game.

config_version=5

[application]

config/name="Null//Drift"
config/description="Cyberpunk hacker game — Godot 3D iso port of hacking-game (Phaser)"
run/main_scene="res://scenes/title.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")

[autoload]

GameState="*res://scripts/systems/game_state.gd"
SaveManager="*res://scripts/systems/save_manager.gd"
Music="*res://scripts/systems/music.gd"
Interaction="*res://scripts/systems/interaction.gd"
DialogueOverlay="*res://scripts/systems/dialogue_overlay.gd"
PhoneState="*res://scripts/systems/phone_state.gd"
StocksState="*res://scripts/systems/stocks_state.gd"
Phone="*res://scripts/systems/phone_overlay.gd"
SceneTransition="*res://scripts/systems/scene_transition.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/size/mode=0
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

